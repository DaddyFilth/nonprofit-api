# Database
DATABASE_URL=sqlite+aiosqlite:///./nonprofit.db

# Email Configuration (Choose one provider)
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_USE_TLS=true

# Gmail API (Alternative to SMTP)
# GMAIL_CLIENT_ID=your_client_id
# GMAIL_CLIENT_SECRET=your_client_secret
# GMAIL_REFRESH_TOKEN=your_refresh_token

# SendGrid (Alternative to SMTP)
# SENDGRID_API_KEY=your_sendgrid_api_key

# Search API (Choose one provider)
SEARCH_PROVIDER=serpapi
SERPAPI_KEY=your_serpapi_key

# Google Custom Search (Alternative to SerpApi)
# GOOGLE_SEARCH_API_KEY=your_google_api_key
# GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id

# LLM Configuration (Choose one provider)
LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key

# Anthropic (Alternative to OpenAI)
# ANTHROPIC_API_KEY=your_anthropic_api_key

# Gemini (Alternative to OpenAI)
# GEMINI_API_KEY=your_gemini_api_key

# Bot Configuration
BOT_EMAIL=procurement@nonprofit.org
BOT_NAME=Material Procurement Bot
ORGANIZATION_NAME=Our Nonprofit

# Organization Identity
ORGANIZATION_MISSION=community-driven initiative providing essential exterior home repair, property restoration, and maintenance for elderly and low-income families at absolutely no cost
ORGANIZATION_LOCATION=Lawton, Oklahoma
ORGANIZATION_OPERATING_NAMES=Lawton Community Restoration Initiative

# Contact Information
CONTACT_NAME=Michael Yessian
REPLY_TO_EMAIL=shinelikeacrime@gmail.com
CONTACT_PHONE=405-204-1427
CONTACT_PHONE_NOTE=Text communication only

# Rate Limiting
MAX_EMAILS_PER_HOUR=20
MAX_SEARCHES_PER_HOUR=30
DELAY_BETWEEN_EMAILS=60

# Logging
LOG_LEVEL=INFO
LOG_FILE=procurement_bot.log